# Database
DATABASE_URL=duckdb://~/code/data-review-database/datareview
DATABASE_LOCATION=~/code/data-review-database/datareview

# API
API_HOST=0.0.0.0
API_PORT=8000

# OpenAI
OPENAI_API_KEY=<your-key-here>

# Database Type
DB_TYPE=duckdb

# Frontend API Configuration
# These environment variables configure where the frontend SvelteKit application
# connects to the backend API server and WebSocket endpoint.
# Use these to deploy to different environments (development, staging, production)
VITE_API_BASE=http://localhost:8000
VITE_WS_BASE=ws://localhost:8000
VITE_FRONTEND_BASE=http://localhost:5173
